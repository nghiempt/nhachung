// Nhà Chung — Prisma Schema
// 46 entities across 13 domain groups.
// All business tables include buildingId for multi-tenant row-level isolation (NFR-SCALE-001).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================================
// ENUMS
// ========================================================

enum UserRole {
  GUEST
  RESIDENT
  PRIMARY_RESIDENT
  BOARD_MEMBER
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ResidentRoleInApartment {
  PRIMARY
  SECONDARY
}

enum FamilyRelation {
  SELF
  SPOUSE
  CHILD
  PARENT
  SIBLING
  GRANDPARENT
  GRANDCHILD
  RELATIVE
  TENANT
  OTHER
}

enum FamilyVerificationStatus {
  VERIFIED
  PENDING
  TEMPORARY
}

enum IdentityDocType {
  CCCD
  CMND
  PASSPORT
  BIRTH_CERT
}

enum VehicleType {
  MOTORCYCLE
  CAR
  BICYCLE
  EV
  OTHER
}

enum NotificationType {
  MANAGEMENT
  EVENT
  FINANCE
  SYSTEM
  URGENT
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum FeeCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
}

enum FundTransactionStatus {
  DONE
  APPROVED
  PENDING
  PLANNED
}

enum FundPlanStatus {
  DONE
  PLANNED
  TENTATIVE
}

enum WorkOrderCategory {
  ELECTRIC
  WATER
  ELEVATOR
  PCCC
  HVAC
  GENERAL
  CIVIL
  SECURITY
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  OVERDUE
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
}

enum TechnicalSystemType {
  PCCC
  LIFT
  ELECTRIC
  WATER
  CCTV
  HVAC
  GENERATOR
  NETWORK
  ACCESS_CONTROL
}

enum TechnicalSystemStatus {
  OK
  WARNING
  DANGER
}

enum KpiCategoryName {
  FINANCE
  MAINTENANCE
  SATISFACTION
  LEGAL
  OPERATIONS
  SECURITY
}

enum KpiRating {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
}

enum KpiIndicatorStatus {
  ON_TRACK
  NEEDS_ATTENTION
  OFF_TRACK
}

enum ReportType {
  MONTHLY
  QUARTERLY
  YEARLY
  ADHOC
}

enum FileType {
  PDF
  DOCX
  XLSX
  JPG
  PNG
  MP4
  OTHER
}

enum NewsCategory {
  MANAGEMENT
  EVENT
  SECURITY
  UTILITY
  URGENT
  COMMUNITY
}

enum EventStatus {
  UPCOMING
  TODAY
  PAST
}

enum FeedbackCategory {
  ELECTRIC
  WATER
  NOISE
  SECURITY
  CLEANLINESS
  ELEVATOR
  PARKING
  SERVICE
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum LinkedAccountProvider {
  GOOGLE
  FACEBOOK
  APPLE
  ZALO
}

enum OwnershipType {
  OWNED
  RENTED
  CORPORATE
}

enum ApartmentStatus {
  ACTIVE
  INACTIVE
  PENDING
}

// ========================================================
// GROUP 1 — AUTH & CORE (5)
// ========================================================

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  phone           String?    @unique
  passwordHash    String
  fullName        String
  dob             DateTime?
  gender          Gender?
  avatar          String?
  role            UserRole   @default(RESIDENT)
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  apartments         ApartmentResident[]
  refreshTokens      RefreshToken[]
  notifications      UserNotification[]
  workOrdersRequested WorkOrder[]        @relation("WorkOrderRequester")
  workOrdersAssigned  WorkOrder[]        @relation("WorkOrderAssignee")
  workOrderUpdates    WorkOrderUpdate[]
  payments           Payment[]
  feedbackReported   Feedback[]         @relation("FeedbackReporter")
  feedbackAssigned   Feedback[]         @relation("FeedbackAssignee")
  feedbackReplies    FeedbackReply[]
  newsPosts          NewsPost[]
  newsViews          NewsPostView[]
  aiConversations    AIConversation[]
  identityDocs       UserIdentityDoc[]
  linkedAccounts     UserLinkedAccount[]
  settings           UserSettings?
  devices            UserDevice[]
  auditLogs          AuditLog[]
  boardMembership    BoardMember[]
  invitationsUsed    InvitationCode[]   @relation("InvitationUsedBy")
  transactionsCreated Transaction[]     @relation("TransactionCreator")
  documentsUploaded  Document[]         @relation("DocumentUploader")

  @@index([email])
  @@index([phone])
  @@index([role, status])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InvitationCode {
  id          String    @id @default(uuid())
  code        String    @unique
  buildingId  String
  apartmentId String?
  expiresAt   DateTime
  usedById    String?
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  building  Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartment Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  usedBy    User?     @relation("InvitationUsedBy", fields: [usedById], references: [id])

  @@index([code])
  @@index([buildingId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ========================================================
// GROUP 2 — BUILDING & APARTMENT (4)
// ========================================================

model Building {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  address          String
  projectName      String?
  totalApartments  Int      @default(0)
  totalFloors      Int      @default(0)
  developerName    String?
  managementCompany String?
  hotline          String?
  description      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  blocks            Block[]
  apartments        Apartment[]
  notifications     Notification[]
  transactions      Transaction[]
  financeCategories FinanceCategory[]
  maintenanceFund   MaintenanceFund?
  workOrders        WorkOrder[]
  technicalSystems  TechnicalSystem[]
  maintenanceSchedules MaintenanceSchedule[]
  kpiPeriods        KpiPeriod[]
  kpiCategories     KpiCategory[]
  boardMembers      BoardMember[]
  periodicReports   PeriodicReport[]
  documentFolders   DocumentFolder[]
  documents         Document[]
  newsPosts         NewsPost[]
  communityEvents   CommunityEvent[]
  feedback          Feedback[]
  invitationCodes   InvitationCode[]

  @@index([code])
}

model Block {
  id         String   @id @default(uuid())
  buildingId String
  name       String
  totalUnits Int      @default(0)
  totalFloors Int     @default(0)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building   Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartments Apartment[]

  @@unique([buildingId, name])
  @@index([buildingId])
}

model Apartment {
  id            String          @id @default(uuid())
  buildingId    String
  blockId       String?
  code          String
  floor         Int
  area          Decimal         @db.Decimal(10, 2)
  bedrooms      Int             @default(1)
  bathrooms     Int             @default(1)
  balconies     Int             @default(0)
  direction     String?
  ownershipType OwnershipType   @default(OWNED)
  contractDate  DateTime?
  handoverDate  DateTime?
  status        ApartmentStatus @default(ACTIVE)
  qrCode        String?         @unique
  floorPlanUrl  String?
  notes         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  building       Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  block          Block?              @relation(fields: [blockId], references: [id], onDelete: SetNull)
  residents      ApartmentResident[]
  familyMembers  FamilyMember[]
  feeSchedules   FeeSchedule[]
  invitationCodes InvitationCode[]

  @@unique([buildingId, code])
  @@index([buildingId])
  @@index([blockId])
}

model ApartmentResident {
  id          String                  @id @default(uuid())
  apartmentId String
  userId      String
  role        ResidentRoleInApartment @default(SECONDARY)
  startDate   DateTime                @default(now())
  endDate     DateTime?

  createdAt DateTime @default(now())

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, userId])
  @@index([userId])
}

// ========================================================
// GROUP 3 — FAMILY (3)
// ========================================================

model FamilyMember {
  id                 String                   @id @default(uuid())
  apartmentId        String
  fullName           String
  relation           FamilyRelation
  cccd               String?
  dob                DateTime?
  gender             Gender?
  occupation         String?
  phone              String?
  email              String?
  avatar             String?
  isPrimary          Boolean                  @default(false)
  verificationStatus FamilyVerificationStatus @default(PENDING)
  notes              String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  apartment Apartment                @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  documents FamilyMemberDocument[]
  vehicles  Vehicle[]

  @@index([apartmentId])
}

model FamilyMemberDocument {
  id         String          @id @default(uuid())
  memberId   String
  type       IdentityDocType
  fileUrl    String
  verifiedAt DateTime?

  createdAt DateTime @default(now())

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model Vehicle {
  id          String      @id @default(uuid())
  memberId    String
  type        VehicleType
  plateNumber String
  brand       String?
  color       String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([plateNumber])
}

// ========================================================
// GROUP 4 — NOTIFICATION (2)
// ========================================================

model Notification {
  id            String               @id @default(uuid())
  buildingId    String
  type          NotificationType
  priority      NotificationPriority @default(NORMAL)
  title         String
  body          String
  source        String?
  attachmentUrl String?
  publishedAt   DateTime             @default(now())

  createdAt DateTime @default(now())

  building   Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  recipients UserNotification[]

  @@index([buildingId, publishedAt])
  @@index([type])
}

model UserNotification {
  id             String    @id @default(uuid())
  userId         String
  notificationId String
  readAt         DateTime?

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId, readAt])
}

// ========================================================
// GROUP 5 — FINANCE (4)
// ========================================================

model FinanceCategory {
  id         String          @id @default(uuid())
  buildingId String
  type       TransactionType
  name       String
  parentId   String?
  color      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  parent   FinanceCategory?  @relation("FinanceCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children FinanceCategory[] @relation("FinanceCategoryTree")
  transactions Transaction[]

  @@unique([buildingId, type, name])
  @@index([buildingId, type])
}

model Transaction {
  id              String          @id @default(uuid())
  buildingId      String
  categoryId      String?
  type            TransactionType
  description     String
  amount          Decimal         @db.Decimal(15, 2)
  transactionDate DateTime
  paymentMethod   String?
  reference       String?
  createdById     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building  Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  category  FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("TransactionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  payments  Payment[]

  @@index([buildingId, transactionDate])
  @@index([type])
}

model FeeSchedule {
  id          String    @id @default(uuid())
  apartmentId String
  name        String
  cycle       FeeCycle  @default(MONTHLY)
  amount      Decimal   @db.Decimal(15, 2)
  dueDate     DateTime
  periodLabel String?
  status      FeeStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([apartmentId, dueDate])
  @@index([status])
}

model Payment {
  id            String   @id @default(uuid())
  feeScheduleId String
  userId        String?
  transactionId String?
  amount        Decimal  @db.Decimal(15, 2)
  paidAt        DateTime
  method        String?
  reference     String?
  notes         String?

  createdAt DateTime @default(now())

  feeSchedule FeeSchedule  @relation(fields: [feeScheduleId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([feeScheduleId])
  @@index([userId])
}

// ========================================================
// GROUP 6 — MAINTENANCE FUND (3)
// ========================================================

model MaintenanceFund {
  id             String   @id @default(uuid())
  buildingId     String   @unique
  currentBalance Decimal  @db.Decimal(15, 2) @default(0)
  bank           String?
  accountNumber  String?
  interestRate   Decimal? @db.Decimal(5, 2)
  foundedDate    DateTime?
  legalBasis     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building     Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  transactions FundTransaction[]
  plans        FundPlan[]
}

model FundTransaction {
  id              String                @id @default(uuid())
  fundId          String
  type            TransactionType
  category        String
  vendor          String?
  description     String
  amount          Decimal               @db.Decimal(15, 2)
  status          FundTransactionStatus @default(DONE)
  transactionDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fund MaintenanceFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, transactionDate])
}

model FundPlan {
  id            String         @id @default(uuid())
  fundId        String
  item          String
  description   String?
  plannedDate   DateTime
  vendor        String?
  estimatedCost Decimal        @db.Decimal(15, 2)
  status        FundPlanStatus @default(PLANNED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fund MaintenanceFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, plannedDate])
}

// ========================================================
// GROUP 7 — OPERATIONS (4)
// ========================================================

model WorkOrder {
  id          String             @id @default(uuid())
  buildingId  String
  code        String             @unique
  title       String
  description String?
  category    WorkOrderCategory
  status      WorkOrderStatus    @default(OPEN)
  priority    WorkOrderPriority  @default(MEDIUM)
  requesterId String
  assigneeId  String?
  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building  Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  requester User              @relation("WorkOrderRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  assignee  User?             @relation("WorkOrderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  updates   WorkOrderUpdate[]
  feedbackLinks FeedbackWorkOrder[]

  @@index([buildingId, status])
  @@index([requesterId])
}

model WorkOrderUpdate {
  id            String           @id @default(uuid())
  workOrderId   String
  userId        String
  comment       String
  statusFrom    WorkOrderStatus?
  statusTo      WorkOrderStatus?
  attachmentUrl String?

  createdAt DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model TechnicalSystem {
  id            String                @id @default(uuid())
  buildingId    String
  name          String
  type          TechnicalSystemType
  lastCheckDate DateTime?
  nextCheckDate DateTime?
  status        TechnicalSystemStatus @default(OK)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, type])
}

model MaintenanceSchedule {
  id            String   @id @default(uuid())
  buildingId    String
  title         String
  description   String?
  scheduledDate DateTime
  scheduledTime String?
  durationMin   Int?
  assigneeName  String?
  category      WorkOrderCategory?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, scheduledDate])
}

// ========================================================
// GROUP 8 — KPI (5)
// ========================================================

model KpiPeriod {
  id          String     @id @default(uuid())
  buildingId  String
  quarter     Int
  year        Int
  totalScore  Decimal?   @db.Decimal(5, 2)
  rating      KpiRating?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building       Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  indicators     KpiIndicator[]
  boardMemberKpi BoardMemberKpi[]

  @@unique([buildingId, year, quarter])
}

model KpiCategory {
  id         String          @id @default(uuid())
  buildingId String
  name       KpiCategoryName
  maxScore   Decimal         @db.Decimal(5, 2) @default(100)

  building   Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  indicators KpiIndicator[]

  @@unique([buildingId, name])
}

model KpiIndicator {
  id              String              @id @default(uuid())
  periodId        String
  categoryId      String
  name            String
  unit            String?
  targetValue     Decimal             @db.Decimal(15, 2)
  actualValue     Decimal             @db.Decimal(15, 2)
  achievementRate Decimal             @db.Decimal(5, 2)
  status          KpiIndicatorStatus  @default(ON_TRACK)
  score           Decimal             @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  period   KpiPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  category KpiCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([periodId])
}

model BoardMember {
  id         String    @id @default(uuid())
  buildingId String
  userId     String
  position   String
  joinDate   DateTime
  leaveDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpis     BoardMemberKpi[]

  @@unique([buildingId, userId])
}

model BoardMemberKpi {
  id            String     @id @default(uuid())
  boardMemberId String
  periodId      String
  score         Decimal    @db.Decimal(5, 2)
  rating        KpiRating

  createdAt DateTime @default(now())

  boardMember BoardMember @relation(fields: [boardMemberId], references: [id], onDelete: Cascade)
  period      KpiPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([boardMemberId, periodId])
}

// ========================================================
// GROUP 9 — REPORTS & DOCUMENTS (3)
// ========================================================

model PeriodicReport {
  id            String     @id @default(uuid())
  buildingId    String
  type          ReportType
  category      String?
  title         String
  period        String
  publishDate   DateTime
  fileUrl       String
  fileType      FileType
  fileSize      Int
  downloadCount Int        @default(0)
  description   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, type, publishDate])
}

model DocumentFolder {
  id         String  @id @default(uuid())
  buildingId String
  name       String
  parentId   String?
  fileCount  Int     @default(0)
  color      String?
  icon       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building  Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  DocumentFolder[] @relation("FolderTree")
  documents Document[]

  @@index([buildingId, parentId])
}

model Document {
  id            String   @id @default(uuid())
  buildingId    String
  folderId      String?
  name          String
  fileType      FileType
  fileUrl       String
  fileSize      Int
  category      String?
  uploadedById  String?
  year          Int?
  month         Int?
  viewCount     Int      @default(0)
  downloadCount Int      @default(0)
  isArchived    Boolean  @default(false)
  description   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  building   Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  folder     DocumentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy User?           @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([buildingId, folderId])
  @@index([buildingId, year, month])
}

// ========================================================
// GROUP 10 — NEWS & COMMUNITY (3)
// ========================================================

model NewsPost {
  id          String       @id @default(uuid())
  buildingId  String
  authorId    String
  title       String
  slug        String
  summary     String
  content     String
  category    NewsCategory
  thumbnail   String?
  isPinned    Boolean      @default(false)
  isFeatured  Boolean      @default(false)
  readTimeMin Int          @default(1)
  viewCount   Int          @default(0)
  publishedAt DateTime     @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  building Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views    NewsPostView[]

  @@unique([buildingId, slug])
  @@index([buildingId, publishedAt])
}

model NewsPostView {
  id       String   @id @default(uuid())
  postId   String
  userId   String
  viewedAt DateTime @default(now())

  post NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model CommunityEvent {
  id          String      @id @default(uuid())
  buildingId  String
  title       String
  description String?
  location    String?
  eventDate   DateTime
  startTime   String?
  endTime     String?
  status      EventStatus @default(UPCOMING)
  thumbnail   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, eventDate])
}

// ========================================================
// GROUP 11 — FEEDBACK (4)
// ========================================================

model Feedback {
  id          String             @id @default(uuid())
  buildingId  String
  userId      String
  category    FeedbackCategory
  title       String
  description String
  priority    FeedbackPriority   @default(MEDIUM)
  status      FeedbackStatus     @default(OPEN)
  assigneeId  String?
  resolvedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  building    Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  user        User                  @relation("FeedbackReporter", fields: [userId], references: [id], onDelete: Cascade)
  assignee    User?                 @relation("FeedbackAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  attachments FeedbackAttachment[]
  replies     FeedbackReply[]
  workOrders  FeedbackWorkOrder[]

  @@index([buildingId, status])
  @@index([userId])
}

model FeedbackAttachment {
  id         String  @id @default(uuid())
  feedbackId String
  fileUrl    String
  mimeType   String?
  fileSize   Int?

  createdAt DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}

model FeedbackReply {
  id           String          @id @default(uuid())
  feedbackId   String
  userId       String
  content      String
  statusChange FeedbackStatus?

  createdAt DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}

model FeedbackWorkOrder {
  feedbackId  String
  workOrderId String

  feedback  Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@id([feedbackId, workOrderId])
}

// ========================================================
// GROUP 12 — AI ASSISTANT (2)
// ========================================================

model AIConversation {
  id            String   @id @default(uuid())
  userId        String
  title         String
  lastMessageAt DateTime @default(now())
  messageCount  Int      @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId, lastMessageAt])
}

model AIMessage {
  id             String        @id @default(uuid())
  conversationId String
  role           AIMessageRole
  content        String
  attachments    Json?
  tokensUsed     Int?
  modelUsed      String?

  createdAt DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ========================================================
// GROUP 13 — PROFILE & SETTINGS (4)
// ========================================================

model UserIdentityDoc {
  id           String          @id @default(uuid())
  userId       String
  type         IdentityDocType
  number       String
  frontUrl     String?
  backUrl      String?
  verifiedAt   DateTime?
  verifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model UserLinkedAccount {
  id         String                @id @default(uuid())
  userId     String
  provider   LinkedAccountProvider
  externalId String
  email      String?
  linkedAt   DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([userId])
}

model UserSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  notifPreferences  Json     @default("{\"email\":true,\"push\":true,\"sms\":false}")
  language          String   @default("vi")
  timezone          String   @default("Asia/Ho_Chi_Minh")
  dateFormat        String   @default("DD/MM/YYYY")
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  privacy           Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDevice {
  id          String    @id @default(uuid())
  userId      String
  deviceName  String
  deviceType  String?
  userAgent   String?
  lastIp      String?
  lastLoginAt DateTime?
  isCurrent   Boolean   @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
